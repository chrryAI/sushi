{
  "name": "ChopStick Payload Builder",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "payload-builder",
        "httpMethod": "POST",
        "responseMode": "lastNode"
      },
      "position": [200, 300]
    },
    {
      "name": "Validate Payload",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const p = $input.first().json.payload;\nif (!p.id && !p.slug && !p.storeSlug) throw new Error('Need id, slug or storeSlug');\nreturn [{ json: { payload: p, jobId: $execution.id } }];"
      },
      "position": [400, 300]
    },
    {
      "name": "ChopStick DB Resolve",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "={{ $env.API_URL }}/api/ai/chopstick/resolve",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [{ "name": "payload", "value": "={{ $json.payload }}" }]
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "position": [600, 300]
    },
    {
      "name": "AI Agent — Prompt Builder",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "parameters": {
        "agent": "openAiFunctionsAgent",
        "promptType": "define",
        "text": "You receive a chopStick-resolved app context. Build the optimal prompt schema. Decide:\n1. Which sources to include (memories/dna/rag/instructions) and their weights\n2. System prompt sections to render\n3. Model selection based on source and capability\n\nApp context:\n{{ JSON.stringify($json.resolvedApp, null, 2) }}\n\nReturn JSON: { sources: [...], modelId: string, sections: [...], reasoning: string }",
        "options": {
          "systemMessage": "You are a prompt architecture expert. Be precise and data-driven."
        }
      },
      "position": [800, 300]
    },
    {
      "name": "Build Final Prompt",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "const schema = JSON.parse($('AI Agent — Prompt Builder').first().json.output);\nconst app = $('ChopStick DB Resolve').first().json.resolvedApp;\n\n// merge AI decision with resolved app\nconst finalPayload = {\n  ...schema,\n  appId: app.id,\n  appName: app.name,\n  renderedAt: new Date().toISOString(),\n};\n\nreturn [{ json: { finalPayload, status: 'done' } }];"
      },
      "position": [1000, 300]
    },
    {
      "name": "Store Result",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "={{ $env.API_URL }}/api/n8n-webhook/result",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "jobId",
              "value": "={{ $('Validate Payload').first().json.jobId }}"
            },
            { "name": "result", "value": "={{ $json.finalPayload }}" },
            { "name": "status", "value": "done" }
          ]
        }
      },
      "position": [1200, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Validate Payload", "type": "main", "index": 0 }]]
    },
    "Validate Payload": {
      "main": [[{ "node": "ChopStick DB Resolve", "type": "main", "index": 0 }]]
    },
    "ChopStick DB Resolve": {
      "main": [
        [{ "node": "AI Agent — Prompt Builder", "type": "main", "index": 0 }]
      ]
    },
    "AI Agent — Prompt Builder": {
      "main": [[{ "node": "Build Final Prompt", "type": "main", "index": 0 }]]
    },
    "Build Final Prompt": {
      "main": [[{ "node": "Store Result", "type": "main", "index": 0 }]]
    }
  }
}
