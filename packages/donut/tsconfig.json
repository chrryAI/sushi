{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["WebWorker", "es2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@chrryai/donut": ["."],
      "@chrryai/donut/*": ["./*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "next.config.mjs",
    "next-auth.d.ts",
    "**/*.ts",
    "**/*.scss",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".eslintrc.js",
    "globals.d.ts",
    "style.d.ts",
    "types/**/*.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "public",
    "dist",
    "**/*.native.tsx",
    "**/*.native.ts",
    "hooks/useMachine.ts",
    "types/architect.ts",
    "tsup.config.ts"
  ]
}
