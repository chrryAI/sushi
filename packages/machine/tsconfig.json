{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext", // ← NodeNext yerine ESNext
    "moduleResolution": "bundler", // ← NodeNext yerine bundler
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@chrryai/machine/*": ["./src/*/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
