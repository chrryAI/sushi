{
  "name": "@chrryai/waffles",
  "version": "2.4.87",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "import": "./dist/test-utils.js",
      "require": "./dist/test-utils.cjs"
    }
  },
  "scripts": {
    "dev": "vp dev run --port 3000",
    "build": "tsup",
    "lint": "eslint .",
    "preview": "vp preview run",
    "e": "pnpm exec playwright install chromium && playwright test --project chromium",
    "e2e": "playwright test --project chromium",
    "ec": "pnpm exec playwright install chromium && playwright test critical.spec.ts --project chromium"
  },
  "dependencies": {
    "@xstate/graph": "^3.0.4",
    "ai": "^6.0.134",
    "ajv": "^8.18.0",
    "effect": "^3.21.0",
    "object-hash": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-node": "^8.0.0",
    "xstate": "^5.30.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
