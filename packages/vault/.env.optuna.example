# =============================================================================
# Optuna Hyperparameter Tuning - Environment Configuration
# Copy this file to .env.optuna and fill in your values
# =============================================================================

# Database Configuration
OPTUNA_DB_PASS=your_secure_password_here
DB_URL=postgresql://optuna:${OPTUNA_DB_PASS}@localhost:5432/optuna

# n8n Configuration
N8N_USER=admin
N8N_PASS=your_n8n_password_here
N8N_WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=your-32-char-encryption-key-here

# LLM API Keys (for actual API trials)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Study Configuration
STUDY_NAME=agent-memory-optimizer
TRIAL_USER_ID=your-test-user-id

# API Configuration (your existing API)
API_URL=http://host.docker.internal:3002

# Worker Configuration
WORKER_ID=1

# Optional: External Storage
# S3_BUCKET=your-optuna-artifacts-bucket
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
