{
  "name": "@chrryai/jules",
  "version": "0.1.0",
  "description": "Zero client-side sync and offline-first state layer",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./permissions": "./src/permissions.ts",
    "./provider": "./src/provider.tsx"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "zero:deploy": "zero-deploy-permissions --schema-path ./zero-schema.ts",
    "zero:generate": "drizzle-zero generate --schema ../machine/src/schema.ts --output ./src/zero-schema.gen.ts --format --force --js-file-extension"
  },
  "dependencies": {
    "@rocicorp/zero": "^1.3.0",
    "drizzle-zero": "^0.18.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
