{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!!packages/sushi",
      "!!**/__tests__/**/*.styles.ts",
      "!apps/flash/public/nato/quick_tips.html",
      "!packages/donut/src/ai/chrry.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "attributePosition": "auto",
    "bracketSpacing": true,
    "useEditorconfig": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "useExhaustiveDependencies": "off",
        "noUnusedImports": "off",
        "noUnusedVariables": "off",
        "noUnusedFunctionParameters": "off",
        "noUnreachable": "off",
        "useHookAtTopLevel": "off",
        "noInnerDeclarations": "off",
        "noUnsafeOptionalChaining": "off",
        "noVoidTypeReturn": "off",
        "noPrecisionLoss": "off",
        "noSelfAssign": "off",
        "noChildrenProp": "off",
        "noConstantCondition": "off",
        "noUnknownTypeSelector": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "suspicious": {
        "noImplicitAnyLet": "off",
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noGlobalIsNan": "warn",
        "noNonNullAssertedOptionalChain": "off",
        "noAssignInExpressions": "off",
        "noControlCharactersInRegex": "off",
        "noShadowRestrictedNames": "off",
        "noDuplicateJsxProps": "warn",
        "noRedeclare": "off",
        "useIterableCallbackReturn": "off"
      },
      "complexity": {
        "noUselessFragments": "off",
        "noForEach": "off",
        "noUselessTernary": "off",
        "noBannedTypes": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "warn",
        "noUnusedTemplateLiteral": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useKeyWithClickEvents": "off",
        "useMediaCaption": "off",
        "noLabelWithoutControl": "off",
        "useValidAnchor": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  }
}
