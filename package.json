    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "replicate": "^1.4.0",
    "tsup": "^8.5.1",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "vconsole": "^3.15.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@vitest/coverage-v8": "4.1.2",
    "bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "is-reference": "^3.0.3",
    "openai": "^6.32.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "vite-plugin-checker": "^0.12.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
