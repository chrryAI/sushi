{
  "name": "vex",
  "version": "2.4.87",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "browser": "bash scripts/run-browser.sh",
    "build": "turbo build",
    "c": "bash scripts/commit-with-ai.sh",
    "check-types": "turbo run check-types",
    "cleanup": "biome check --write --unsafe .",
    "cleanup:unused": "node scripts/remove-unused.js",
    "dev": "concurrently \"turbo dev --filter=api\" \"turbo dev --filter=flash\"",
    "dev:all": "concurrently \"turbo dev --filter=api\" \"turbo dev --filter=flash\"",
    "docker:clean": "docker-compose -f infra/docker/docker-compose.local.yml down -v",
    "docker:logs": "docker-compose -f infra/docker/docker-compose.local.yml logs -f",
    "docker:restart": "pnpm docker:stop && pnpm docker:start",
    "docker:start": "bash scripts/dev/start-local-stack.sh",
    "docker:stop": "docker-compose -f infra/docker/docker-compose.local.yml down",
    "docs:build": "NODE_OPTIONS='--max-old-space-size=8192' typedoc",
    "docs:build:markdown": "NODE_OPTIONS='--max-old-space-size=8192' typedoc --options typedoc.markdown.json",
    "docs:serve": "npx serve docs/api",
    "docs:watch": "NODE_OPTIONS='--max-old-space-size=8192' typedoc --watch",
    "e2e": "pnpm run generate && pnpm run migrate && pnpm run seed && turbo run e2e --filter=@chrryai/waffles --log-order=stream",
    "format": "biome format --write .",
    "generate": "NODE_ENV=production turbo run generate --filter=@chrryai/machine --log-order=stream",
    "generate:icons": "bash scripts/generate-app-icons.sh",
    "i": "rm -rf node_modules && rm -f package-lock.json && pnpm install",
    "lint": "biome check --write .",
    "lint:fix": "biome check --write .",
    "local:setup": "pnpm docker:start && cd packages/vault && pnpm run generate && pnpm run migrate && pnpm run seed",
    "migrate": "NODE_ENV=production turbo run migrate --filter=@chrryai/machine --log-order=stream",
    "native": "cd apps/native && npm start",
    "nuke": "bash scripts/deploy/nuke.sh",
    "nuke:down": "docker compose -f infra/docker/docker-compose.nuke.yml down",
    "nuke:down-v": "docker compose -f infra/docker/docker-compose.nuke.yml down -v",
    "p": "npm run lint && git push",
    "pdf": "pandoc PITCH_DECK.md -o PITCH_DECK.pdf --pdf-engine=xelatex -V geometry:margin=1in --toc",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { require('node:child_process').execSync('husky', { stdio: 'inherit' }) }\" || true",
    "publish": "bash scripts/publish-all.sh",
    "s": "node scripts/scss-to-universal.js",
    "s:all": "node scripts/scss-to-universal.js --all",
    "s:changed": "node scripts/convert-changed-scss.js",
    "s:w": "node scripts/watch-scss.js",
    "seed": "NODE_ENV=production turbo run seed --filter=@chrryai/machine --log-order=stream",
    "setup:env": "bash scripts/setup-env.sh",
    "sp": "cd apps/api && npx tsx cron/sync-plausible.ts",
    "start:all": "concurrently \"turbo start --filter=api\" \"turbo start --filter=flash\"",
    "start:api": "turbo run start --log-order=stream --filter=api",
    "start:flash": "turbo run start --log-order=stream --filter=flash",
    "t": "node scripts/translate.js",
    "test": "turbo run test --log-order=stream",
    "test:coverage": "turbo run test:coverage --log-order=stream",
    "test:e2e": "turbo run e2e --log-order=stream --filter=@chrryai/waffles",
    "test:integration": "turbo run test:integration --log-order=stream --filter=@chrryai/waffles",
    "test:scss": "node scripts/test-scss-converter.js",
    "test:unit": "turbo run test --log-order=stream --filter=!@chrryai/waffles",
    "test-ai": "bash scripts/test-commit-message.sh",
    "translate": "node scripts/translate.js",
    "update-version": "node scripts/update-version.js",
    "validate:chrry": "node scripts/validate-chrry-config.js"
  },
  "overrides": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.12",
    "minimist": "^1.2.8",
    "node-forge": "^1.3.2",
    "prismjs": "1.30.0",
